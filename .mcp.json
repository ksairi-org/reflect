{
  "mcpServers": {
    "expo": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/mcp-run.sh",
      "args": ["node", "${CLAUDE_PLUGIN_ROOT}/mcps/expo-mcp-server/dist/index.js"],
      "env": {
        "NODE_PATH": "${CLAUDE_PLUGIN_ROOT}/mcps/expo-mcp-server/node_modules"
      }
    },
    "database": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/mcp-run.sh",
      "args": ["node", "${CLAUDE_PLUGIN_ROOT}/mcps/database-mcp-server/dist/index.js"],
      "env": {
        "NODE_PATH": "${CLAUDE_PLUGIN_ROOT}/mcps/database-mcp-server/node_modules"
      }
    },
    "figma": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/mcp-run.sh",
      "args": ["npx", "-y", "figma-developer-mcp", "--stdio"]
    },
    "github": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/mcp-run.sh",
      "args": ["npx", "-y", "@modelcontextprotocol/server-github"]
    },
    "sentry": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/mcp-run.sh",
      "args": ["npx", "-y", "@sentry/mcp-server@latest", "--organization-slug=${SENTRY_ORG}"],
      "env": {
        "SENTRY_AUTH_TOKEN": "${SENTRY_AUTH_TOKEN}"
      }
    },
    "stripe": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/mcp-run.sh",
      "args": ["npx", "-y", "@stripe/mcp", "--tools=all"]
    },
    "doppler": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/mcp-run.sh",
      "args": ["npx", "-y", "@dopplerhq/mcp-server"]
    },
    "firebase": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/mcp-run.sh",
      "args": ["npx", "-y", "firebase-tools@latest", "experimental:mcp"]
    },
    "supabase": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/mcp-run.sh",
      "args": ["npx", "-y", "@supabase/mcp-server-supabase@latest", "--access-token=${SUPABASE_ACCESS_TOKEN}"]
    },
    "context7": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/mcp-run.sh",
      "args": ["npx", "-y", "@upstash/context7-mcp@latest"]
    }
  }
}
