#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
msgid "Delete your {serverCount} account {0} and keep your {localCount} local {1}."
msgstr "احذف {serverCount} {0} من حسابك واحتفظ بـ{localCount} {1} المحلية."

#. placeholder {0}: localCount === 1 ? 'entry' : 'entries'
#. placeholder {1}: serverCount === 1 ? 'one' : 'ones'
#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
msgid "Discard your {localCount} local {0} and continue with your {serverCount} saved {1}."
msgstr "تجاهل {localCount} {0} المحلية واستمر مع {serverCount} {1} المحفوظة."

#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
msgid "Keep account entries"
msgstr "الاحتفاظ بإدخالات الحساب"

#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
msgid "Keep everything ✦"
msgstr "الاحتفاظ بالكل ✦"

#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
msgid "Keep local entries"
msgstr "الاحتفاظ بالإدخالات المحلية"

#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
msgid "Merge all"
msgstr "دمج الكل"

#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
msgid "Merge all {combined} entries into your account."
msgstr "دمج جميع {combined} إدخالاً في حسابك."

#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
msgid "One more thing"
msgstr "شيء واحد آخر"

#: src/components/molecules/JournalEntry/SwipeableDeleteWrapper.tsx
msgid "This cannot be undone."
msgstr "لا يمكن التراجع عن هذا."

#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
msgid "Unlimited entries unlocked. Keep writing."
msgstr "تم فتح إدخالات غير محدودة. استمر في الكتابة."

#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
msgid "Upgrade to Pro to merge all {combined} entries and write without limits."
msgstr "قم بالترقية إلى Pro لدمج جميع {combined} إدخالاً والكتابة بلا حدود."

#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
msgid "Welcome to Pro ✦"
msgstr "مرحباً بك في Pro ✦"

#. placeholder {0}: localCount === 1 ? 'entry' : 'entries'
#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
msgid "You have {localCount} local {0} and {serverCount} in your account — {combined} total, {overBy} over the free limit of {FREE_ENTRY_LIMIT}."
msgstr "لديك {localCount} {0} محلية و{serverCount} في حسابك — {combined} إجمالاً، بزيادة {overBy} عن الحد المجاني البالغ {FREE_ENTRY_LIMIT}."

#. placeholder {0}: serverCount === 1 ? 'entry' : 'entries'
#. placeholder {1}: localCount === 1 ? 'entry' : 'entries'
#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
msgid "Your {serverCount} account {0} will be permanently deleted and replaced with your {localCount} local {1}."
msgstr "ستُحذف {serverCount} {0} من حسابك نهائياً وتُستبدل بـ{localCount} {1} المحلية."
