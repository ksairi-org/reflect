#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
#: src/components/molecules/JournalEntry/SwipeableDeleteWrapper.tsx
msgid "Cancel"
msgstr "إلغاء"

#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
msgid "Decide later — review local entries first"
msgstr "قرر لاحقاً — راجع الإدخالات المحلية أولاً"

#: src/components/molecules/JournalEntry/SwipeableDeleteWrapper.tsx
msgid "Delete"
msgstr "حذف"

#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
msgid "Delete & keep local"
msgstr "احذف واحتفظ بالمحلية"

#: src/components/molecules/AnonMergeModal/AnonMergeModal.tsx
msgid "Delete account entries?"
msgstr "حذف إدخالات الحساب؟"

#: src/components/molecules/JournalEntry/SwipeableDeleteWrapper.tsx
msgid "Delete entry?"
msgstr "حذف المدخلة؟"

#. placeholder {0}: serverCount === 1 ? 'entry' : 'entries'
