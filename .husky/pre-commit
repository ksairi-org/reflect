#!/usr/bin/env sh
. "$(dirname "$0")/common.sh"

# If any source file is staged, extract new i18n strings and re-stage the .po catalogs
if git diff --cached --name-only | grep -qE '\.(tsx?|jsx?)$'; then
  yarn lingui extract
  git add src/i18n/locales/exported/
fi

# Always recompile and re-stage compiled catalogs if they differ from HEAD
# EAS local builds archive via git so compiled files must always be committed
yarn lingui compile
git add src/i18n/locales/compiled/
