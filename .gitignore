# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*
.watchmanconfig

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# Tamagui extraction cache (disableExtraction: true — this file is unused)
.tamagui/

app-example

# Supabase CLI temp files
supabase/.temp/

# generated native folders
/ios
/android
.env

# Yarn
.yarn/install-state.gz

# Lingui compiled output is committed — EAS local builds archive via git and cannot regenerate it

# Digital Asset Links — belongs on galagym.com, not in this repo
assetlinks.json

# Firebase service account key (has admin privileges — never commit)
*firebase-adminsdk*.json
firebase-service-account.json
# Google Play service account key (sensitive — store in CI secrets, never commit)
eas-service-account.json

# EAS local build artifacts
*.tar.gz
*.apk
*.ipa
*.aab
*.app
