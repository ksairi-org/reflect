# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android
.env

# Yarn
.yarn/install-state.gz

# Lingui compiled output (regenerated by yarn i18n on every start/build)
src/i18n/locales/compiled/

# Firebase service account key (has admin privileges — never commit)
*firebase-adminsdk*.json
# Google Play service account key (sensitive — store in CI secrets, never commit)
eas-service-account.json

# EAS local build artifacts
build-*.tar.gz
build-*.apk
app-build.ipa
app-build.aab
*.app
