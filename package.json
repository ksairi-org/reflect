    "@types/aes-js": "^3",
    "@types/babel__core": "^7",
    "@types/inflected": "^2",
    "@types/jest": "29.5.14",
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-inline-import": "^3.0.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "expo-build-properties": "^55.0.13",
    "husky": "^9.1.7",
    "inflected": "^2.1.0",
    "jest-expo": "~55.0.16",
    "orval": "^8.9.0",
