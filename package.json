    "tamagui": "^2.0.0-rc.41",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/runtime": "^7.29.2",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@lingui/cli": "^6.0.0",
    "@lingui/format-po": "^6.0.0",
    "@phenomnomnominal/tsquery": "^6.2.0",
    "@tamagui/babel-plugin": "^2.0.0-rc.41",
