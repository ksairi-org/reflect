{
  "name": "reflect",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "sync-env-vars": "doppler secrets substitute env.template.yaml --output .env --project mobile --config ${1:-stg}",
    "sync-design-tokens": "doppler run -- bash -c \"FIGMA_TOKEN=$FIGMA_API_KEY figma-tamagui-sync --fileId=$FIGMA_FILE_ID --out=./src/theme\"",
    "generate:open-api-spec": "node node_modules/@ksairi-org/react-query-sdk/scripts/generate-open-api-spec.js",
    "generate:open-api-hooks": "yarn generate:open-api-spec && yarn orval --config node_modules/@ksairi-org/react-query-sdk/orval.config.ts",
    "pre-start": "yarn sync-env-vars $1; yarn sync-design-tokens; yarn generate:open-api-hooks; $2",
    "start:expo": "[ ${1:-stg} == 'prd' ] && yarn expo start --scheme reflect || yarn expo start --scheme reflect-${1:-stg}",
    "start": "yarn i18n && yarn pre-start ${1:-stg} \"yarn start:expo ${1:-stg}\"",
    "build": "yarn sync-env-vars ${1:-stg}; yarn generate:open-api-hooks; $2",
    "pre-build": "yarn i18n && yarn build ${1:-stg} \"$2\"",
    "dev-client-ios": "yarn pre-build ${1:-stg} \"eas build --platform ios --profile development --local\"",
    "dev-client-android": "yarn pre-build ${1:-stg} \"eas build --platform android --profile development --local\"",
    "dev-client-ios-device": "yarn pre-build ${1:-stg} \"eas build --platform ios --profile preview --local\"",
    "build-store-ios": "yarn pre-build ${1:-stg} \"eas build --platform ios --profile production --local --non-interactive --output ./app-build.ipa\"",
    "build-store-android": "yarn pre-build ${1:-stg} \"eas build --platform android --profile production --local --non-interactive --output ./app-build.aab\"",
    "build-store-all": "yarn build-store-android ${1:-stg} && yarn build-store-ios ${1:-stg}",
    "deploy-store-ios": "yarn build-store-ios ${1:-stg} && eas submit --platform ios --profile ${1:-stg} --path ./app-build.ipa",
    "deploy-store-android": "yarn build-store-android ${1:-stg} && eas submit --platform android --profile ${1:-stg} --path ./app-build.aab",
    "deploy-store-all": "yarn deploy-store-android ${1:-stg} && yarn deploy-store-ios ${1:-stg}",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --watchAll=false",
    "test:watch": "jest",
    "check:tsc": "tsc --noEmit",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile",
    "i18n": "yarn i18n:extract && yarn i18n:compile",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/log-box": "^55.0.11",
    "@expo/vector-icons": "^15.0.3",
    "@ksairi-org/react-hooks": "^0.1.1",
    "@ksairi-org/react-native-functions": "^0.1.1",
    "@ksairi-org/react-native-hooks": "^0.1.1",
    "@ksairi-org/react-native-ui-config": "^0.1.1",
    "@ksairi-org/react-query-sdk": "^0.1.1",
    "@ksairi-org/ui-button": "^0.1.9",
    "@ksairi-org/ui-button-animated": "^0.1.5",
    "@ksairi-org/ui-containers": "^0.1.10",
    "@ksairi-org/ui-touchables": "^0.1.4",
    "@lingui/core": "^6.0.0",
    "@lingui/macro": "^5.9.5",
    "@lingui/react": "^6.0.0",
    "@react-native-community/hooks": "^3.0.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-firebase/analytics": "^24.0.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.105.0",
    "@tamagui/config": "^2.0.0-rc.41",
    "@tamagui/core": "^2.0.0-rc.41",
    "@tanstack/react-query": "^5.100.6",
    "axios": "^1.15.2",
    "burnt": "^0.13.0",
    "expo": "^55.0.18",
    "expo-constants": "~55.0.15",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.9",
    "expo-linking": "~55.0.14",
    "expo-localization": "^55.0.13",
    "expo-notifications": "^55.0.21",
    "expo-router": "~55.0.13",
    "expo-secure-store": "^55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.16",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-purchases": "^10.0.1",
    "react-native-purchases-ui": "^10.0.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "rive-react-native": "^9.8.3",
    "tamagui": "^2.0.0-rc.41",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/runtime": "^7.29.2",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@lingui/cli": "^6.0.0",
    "@lingui/format-po": "^6.0.0",
    "@tamagui/babel-plugin": "^2.0.0-rc.41",
    "@testing-library/react-native": "^13.3.3",
    "@types/babel__core": "^7",
    "@types/jest": "29.5.14",
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-inline-import": "^3.0.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "expo-build-properties": "^55.0.13",
    "husky": "^9.1.7",
    "jest-expo": "~55.0.16",
    "orval": "^8.9.0",
    "prettier": "^3.8.3",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "19.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-language-server": "^5.1.3"
  },
  "private": true,
  "packageManager": "yarn@4.9.2"
}
