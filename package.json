    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.105.0",
    "@tamagui/config": "^2.0.0-rc.41",
    "@tamagui/core": "^2.0.0-rc.41",
    "@tanstack/react-query": "^5.100.6",
    "aes-js": "^3.1.2",
    "axios": "^1.15.2",
    "burnt": "^0.13.0",
    "expo": "^55.0.18",
    "expo-constants": "~55.0.15",
    "expo-dev-client": "~55.0.30",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.9",
    "expo-linking": "~55.0.14",
    "expo-localization": "^55.0.13",
    "expo-notifications": "^55.0.21",
    "expo-router": "~55.0.13",
    "expo-secure-store": "^55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.16",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
