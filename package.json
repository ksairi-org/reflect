{
  "name": "reflect",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "sync-env-vars": "doppler secrets substitute env.template.yaml --output .env --project mobile --config ${0:-stg}",
    "sync-design-tokens": "doppler run --project mobile --config ${0:-stg} -- bash -c 'if [ -z \"${FIGMA_API_KEY:-}\" ] || [ -z \"${FIGMA_FILE_ID:-}\" ]; then echo \"Skipping design token sync (no Figma project configured)\"; else FIGMA_TOKEN=$FIGMA_API_KEY figma-tamagui-sync --fileId=$FIGMA_FILE_ID --out=./src/theme; fi'",
    "generate:open-api-spec": "bash -c 'mkdir -p node_modules/@ksairi-org/react-query-sdk/specs && EXPO_PUBLIC_SUPABASE_API_KEY=$(grep ^SUPABASE_SERVICE_ROLE_KEY= .env | cut -d= -f2-) node --env-file=.env node_modules/@ksairi-org/react-query-sdk/scripts/generate-open-api-spec.js'",
    "generate:open-api-hooks": "yarn generate:open-api-spec && node --env-file=.env node_modules/.bin/orval --config node_modules/@ksairi-org/react-query-sdk/orval.config.ts",
    "pre-start": "yarn sync-env-vars $0 && yarn sync-design-tokens $0 && yarn generate:open-api-hooks",
    "start:expo": "[ ${0:-stg} == 'prd' ] && yarn expo start --scheme reflect || yarn expo start --scheme reflect-${0:-stg}",
    "start": "yarn i18n && yarn pre-start $0 && yarn start:expo $0",
    "build": "yarn sync-env-vars $0 && yarn generate:open-api-hooks; $1",
    "pre-build": "yarn i18n && yarn build $0 \"$1\"",
    "dev-client-ios": "yarn pre-build $0 \"eas build --platform ios --profile development --local\"",
    "dev-client-android": "yarn pre-build $0 \"eas build --platform android --profile development --local\"",
    "dev-client-ios-device": "yarn pre-build $0 \"eas build --platform ios --profile preview --local\"",
    "build-store-ios": "yarn pre-build $0 \"eas build --platform ios --profile prd --local --non-interactive --output ./app-build.ipa\"",
    "build-store-android": "yarn pre-build $0 \"eas build --platform android --profile prd --local --non-interactive --output ./app-build.aab\"",
    "build-store-all": "yarn build-store-android $0 && yarn build-store-ios $0",
    "deploy-store-ios": "yarn build-store-ios $0 && eas submit --platform ios --profile $0 --path ./app-build.ipa",
    "deploy-store-android": "yarn build-store-android $0 && eas submit --platform android --profile $0 --path ./app-build.aab",
    "deploy-store-all": "yarn deploy-store-android $0 && yarn deploy-store-ios $0",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --watchAll=false",
    "test:watch": "jest",
    "check:tsc": "tsc --noEmit",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile",
    "i18n": "yarn i18n:extract && yarn i18n:compile",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/lora": "^0.4.2",
    "@expo/log-box": "^55.0.11",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@invertase/react-native-apple-authentication": "^2.5.1",
    "@ksairi-org/expo-image": "^0.1.2",
    "@ksairi-org/react-auth-client": "^0.1.1",
    "@ksairi-org/react-auth-core": "^0.1.1",
    "@ksairi-org/react-auth-hooks": "^0.1.2",
    "@ksairi-org/react-auth-setup": "^0.1.1",
    "@ksairi-org/react-auth-storage": "^0.1.2",
    "@ksairi-org/react-form": "^0.1.2",
    "@ksairi-org/react-hooks": "^0.1.1",
    "@ksairi-org/react-native-auth-apple": "^0.1.1",
    "@ksairi-org/react-native-auth-google": "^0.1.1",
    "@ksairi-org/react-native-functions": "^0.1.1",
    "@ksairi-org/react-native-hooks": "^0.1.1",
    "@ksairi-org/react-native-splash-view": "0.1.3",
    "@ksairi-org/react-native-ui-config": "^0.1.3",
    "@ksairi-org/react-query-sdk": "^0.1.2",
    "@ksairi-org/ui-button": "^0.1.11",
